{
  "name": "planner-electron",
  "version": "1.1.0",
  "description": "Preschool Teacher Scheduling Application - Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder build --mac --arm64 --x64",
    "dist-slim": "electron-builder build --mac --x64 --config electron-build-slim.json",
    "dist-slim-win": "electron-builder build --win --x64 --config electron-build-slim-win.json"
  },
  "build": {
    "appId": "com.planner.app",
    "productName": "Planner",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg" }
      ]
    },
    "dmg": {
      "title": "Planner"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      { "from": "build/planner-backend.jar",   "to": "planner-backend.jar" },
      { "from": "build/frontend-dist",         "to": "frontend" },
      { "from": "build/jre/mac-${arch}",       "to": "jre" }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
