{
  "appId": "com.planner.app",
  "productName": "Planner",
  "compression": "maximum",
  "win": {
    "icon": "build/icon.ico",
    "target": [
      { "target": "portable", "arch": ["x64"] }
    ]
  },
  "files": [
    "main.js",
    "preload.js",
    "package.json"
  ],
  "extraResources": [
    { "from": "build/planner-backend.jar", "to": "planner-backend.jar" },
    { "from": "build/frontend-dist",       "to": "frontend" },
    { "from": "build/jre/win-x64-slim",    "to": "jre" }
  ]
}
